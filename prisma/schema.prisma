generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           Int      @id @default(autoincrement())
  nombre       String
  email        String   @unique
  passwordHash String   @map("password_hash")
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")

  equipos              Equipo[]
  gameScores           GameScore[]
  anotadorAsignaciones AnotadorAsignacion[]
  anotaciones          Anotacion[]
}

model GameScore {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  score     Int
  tries     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([score(sort: Desc)])
}

model Temporada {
  id          Int      @id @default(autoincrement())
  nombre      String
  activa      Boolean  @default(false)
  fechaInicio DateTime @map("fecha_inicio")
  fechaFin    DateTime @map("fecha_fin")
  createdAt   DateTime @default(now()) @map("created_at")

  fechas  Fecha[]
  equipos Equipo[]
}

model Jugador {
  id        Int      @id @default(autoincrement())
  nombre    String
  apellido  String
  apodo     String?
  camada    Int?
  posicion  Posicion
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  jugadorFechas        JugadorFecha[]
  equipoFechaJugadores EquipoFechaJugador[]
}

model Fecha {
  id              Int         @id @default(autoincrement())
  temporadaId     Int         @map("temporada_id")
  nro             Int
  rival           String
  estado          EstadoFecha @default(BORRADOR)
  cierraEdicionAt DateTime?   @map("cierra_edicion_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  temporada            Temporada            @relation(fields: [temporadaId], references: [id])
  jugadorFechas        JugadorFecha[]
  equipoFechas         EquipoFecha[]
  anotadorAsignaciones AnotadorAsignacion[]
  partidos             Partido[]

  @@unique([temporadaId, nro])
}

model JugadorFecha {
  id               Int      @id @default(autoincrement())
  jugadorId        Int      @map("jugador_id")
  fechaId          Int      @map("fecha_id")
  plantel          Plantel
  tries            Int      @default(0)
  tackles          Int      @default(0)
  knockOns         Int      @default(0) @map("knock_ons")
  penales          Int      @default(0)
  amarillas        Int      @default(0)
  rojas            Int      @default(0)
  conversionesMetidas Int      @default(0) @map("conversiones_metidas")
  conversionesErradas Int      @default(0) @map("conversiones_erradas")
  penalesMetidos      Int      @default(0) @map("penales_metidos")
  penalesErrados      Int      @default(0) @map("penales_errados")
  puntajeCalculado    Int      @default(0) @map("puntaje_calculado")
  puntajeOverride     Int?     @map("puntaje_override")
  updatedAt           DateTime @updatedAt @map("updated_at")

  jugador     Jugador     @relation(fields: [jugadorId], references: [id])
  fecha       Fecha       @relation(fields: [fechaId], references: [id])
  anotaciones Anotacion[]

  @@unique([fechaId, jugadorId])
}

model Equipo {
  id          Int      @id @default(autoincrement())
  usuarioId   Int      @map("usuario_id")
  temporadaId Int      @map("temporada_id")
  nombre      String
  createdAt   DateTime @default(now()) @map("created_at")

  usuario      Usuario       @relation(fields: [usuarioId], references: [id])
  temporada    Temporada     @relation(fields: [temporadaId], references: [id])
  equipoFechas EquipoFecha[]

  @@unique([temporadaId, usuarioId])
}

model EquipoFecha {
  id               Int      @id @default(autoincrement())
  equipoId         Int      @map("equipo_id")
  fechaId          Int      @map("fecha_id")
  puntajeTotal      Int      @default(0) @map("puntaje_total")
  capitanJugadorId  Int?     @map("capitan_jugador_id")
  pateadorJugadorId Int?     @map("pateador_jugador_id")
  createdAt         DateTime @default(now()) @map("created_at")

  equipo    Equipo               @relation(fields: [equipoId], references: [id])
  fecha     Fecha                @relation(fields: [fechaId], references: [id])
  jugadores EquipoFechaJugador[]

  @@unique([equipoId, fechaId])
}

model EquipoFechaJugador {
  id            Int @id @default(autoincrement())
  equipoFechaId Int @map("equipo_fecha_id")
  jugadorId     Int @map("jugador_id")
  slot          Int @default(0)

  equipoFecha EquipoFecha @relation(fields: [equipoFechaId], references: [id])
  jugador     Jugador     @relation(fields: [jugadorId], references: [id])

  @@unique([equipoFechaId, jugadorId])
}

enum Posicion {
  FORWARD
  BACK
  PILAR
  HOOKER
  SEGUNDA_LINEA
  TERCERA_LINEA
  MEDIO_SCRUM
  APERTURA
  CENTRO
  WING
  FULLBACK
}

enum Plantel {
  PRIMERA
  INTER
  PRE_A
  PRE_B
  PRE_C
  PRE_D
}

enum EstadoFecha {
  BORRADOR
  PREVIA
  CERRADA
  PUNTUADA
}

model AnotadorAsignacion {
  id        Int      @id @default(autoincrement())
  fechaId   Int      @map("fecha_id")
  usuarioId Int      @map("usuario_id")
  plantel   Plantel
  createdAt DateTime @default(now()) @map("created_at")

  fecha   Fecha   @relation(fields: [fechaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([fechaId, plantel])
  @@index([usuarioId, fechaId])
}

enum EstadoPartido {
  NO_INICIADO
  EN_CURSO
  FINALIZADO
}

model Partido {
  id           Int           @id @default(autoincrement())
  fechaId      Int           @map("fecha_id")
  plantel      Plantel
  estado       EstadoPartido @default(NO_INICIADO)
  iniciadoAt   DateTime?     @map("iniciado_at")
  finalizadoAt DateTime?     @map("finalizado_at")
  createdAt    DateTime      @default(now()) @map("created_at")

  fecha       Fecha       @relation(fields: [fechaId], references: [id])
  anotaciones Anotacion[]

  @@unique([fechaId, plantel])
}

enum AccionTipo {
  TRY
  TACKLE
  KNOCK_ON
  PENAL
  AMARILLA
  ROJA
  CONVERSION_METIDA
  CONVERSION_ERRADA
  PENAL_METIDO
  PENAL_ERRADO
}

model Anotacion {
  id             Int        @id @default(autoincrement())
  partidoId      Int        @map("partido_id")
  jugadorFechaId Int        @map("jugador_fecha_id")
  accion         AccionTipo
  anotadorId     Int        @map("anotador_id")
  revertida      Boolean    @default(false)
  createdAt      DateTime   @default(now()) @map("created_at")
  revertidaAt    DateTime?  @map("revertida_at")

  partido      Partido      @relation(fields: [partidoId], references: [id])
  jugadorFecha JugadorFecha @relation(fields: [jugadorFechaId], references: [id])
  anotador     Usuario      @relation(fields: [anotadorId], references: [id])

  @@index([partidoId, revertida, createdAt(sort: Desc)])
}
